{
  "name": "imobi-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:push": "turbo run db:push --filter=@imobi/db",
    "db:migrate": "turbo run db:migrate --filter=@imobi/db",
    "db:studio": "turbo run db:studio --filter=@imobi/db",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "claude-review": "tsx scripts/claude-review.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "dotenv": "^16.4.5",
    "zx": "^8.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0"
  }
}

