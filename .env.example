# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/imobi_platform
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
NEXTAUTH_SECRET=your-nextauth-secret

# WhatsApp (Meta Cloud API)
META_WHATSAPP_TOKEN=your-meta-whatsapp-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-meta-app-secret

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@imobi.com.br

# Storage (Cloudflare R2 or AWS S3)
S3_BUCKET=imobi-uploads
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Payments (Asaas)
ASAAS_API_KEY=your-asaas-key
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# E-signature (Clicksign)
CLICKSIGN_API_KEY=your-clicksign-key
CLICKSIGN_BASE_URL=https://sandbox.clicksign.com

# Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001
NODE_ENV=development
